# ─── ShelterConnect API — Environment Variables ─────────────
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to version control.

# ─── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/shelterconnect

# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development    # 'development' | 'production'

# ─── Authentication (REQUIRED — server will not start without these) ──
JWT_SECRET=             # Long random string for signing access tokens
REFRESH_SECRET=         # Long random string for signing refresh tokens

# ─── Token Expiry ────────────────────────────────────────────
JWT_EXPIRY=15m          # Access token lifetime (e.g. 15m, 1h)
REFRESH_EXPIRY=7d       # Refresh token lifetime (e.g. 7d, 30d)

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000    # Frontend URL
